<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>STRIX // {{ report.target }}</title>
<style>
  :root {
    --green: #00ff41;
    --green-dim: #1f8b3a;
    --green-deep: #0a3d1a;
    --bg: #050805;
    --bg2: #0a0f0a;
    --amber: #ffb000;
    --red: #ff003c;
    --text: #b6ffc4;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: "SF Mono", ui-monospace, "Cascadia Code", Consolas, monospace;
    color: var(--text);
    background: radial-gradient(ellipse at top, var(--bg2), var(--bg));
    background-attachment: fixed;
    min-height: 100vh;
    padding: 2rem 1rem 4rem;
    line-height: 1.55;
    text-shadow: 0 0 4px rgba(0, 255, 65, .25);
  }
  /* CRT scanlines */
  body::before {
    content: "";
    position: fixed; inset: 0; z-index: 9999; pointer-events: none;
    background: repeating-linear-gradient(
      to bottom, rgba(0,0,0,0) 0, rgba(0,0,0,0) 2px, rgba(0,0,0,.18) 3px, rgba(0,0,0,0) 4px);
    mix-blend-mode: multiply;
  }
  .wrap { max-width: 1080px; margin: 0 auto; }
  a { color: var(--green); text-decoration: none; border-bottom: 1px dashed var(--green-dim); }
  a:hover { background: var(--green); color: #000; text-shadow: none; }

  .prompt { color: var(--green-dim); }
  .blink { animation: blink 1s steps(2, start) infinite; }
  @keyframes blink { to { opacity: 0; } }

  header.hero {
    border: 1px solid var(--green-dim);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.75rem;
    background: rgba(0, 255, 65, .03);
    box-shadow: 0 0 24px rgba(0, 255, 65, .08), inset 0 0 24px rgba(0, 255, 65, .03);
  }
  header.hero h1 {
    margin: 0;
    font-size: 2.4rem;
    letter-spacing: .5rem;
    color: var(--green);
    text-shadow: 0 0 10px rgba(0,255,65,.6), 2px 0 var(--red), -2px 0 #00e0ff;
  }
  header.hero .sub { color: var(--green-dim); font-size: .85rem; margin: .25rem 0 1rem; }
  .meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: .4rem 1.5rem; font-size: .85rem; }
  .meta .k { color: var(--green-dim); }
  .meta .v { color: var(--green); font-weight: 700; }

  .card {
    border: 1px solid var(--green-deep);
    border-left: 3px solid var(--green);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.25rem;
    background: rgba(0, 255, 65, .02);
  }
  .card h2 {
    margin: 0 0 .5rem; font-size: 1.05rem; color: var(--green);
    display: flex; gap: .6rem; align-items: baseline;
  }
  .card h2::before { content: "root@strix:~#"; color: var(--green-dim); font-weight: 400; }
  .card h2 .dur { color: var(--green-dim); font-size: .75rem; font-weight: 400; margin-left: auto; }
  .error { color: var(--red); }
  .empty { color: var(--green-dim); font-style: italic; }

  table { width: 100%; border-collapse: collapse; margin-top: .5rem; font-size: .85rem; }
  th, td { text-align: left; padding: .35rem .6rem; border-bottom: 1px solid rgba(0,255,65,.08); vertical-align: top; }
  th { color: var(--green-dim); text-transform: uppercase; font-size: .68rem; letter-spacing: .08em; }
  td.value { word-break: break-all; color: var(--text); }

  .badge { display: inline-block; padding: 0 .5rem; border-radius: 2px; font-size: .7rem;
           font-weight: 700; text-transform: uppercase; border: 1px solid currentColor; }
  .sev-info { color: var(--green-dim); }
  .sev-low { color: var(--green); }
  .sev-medium { color: var(--amber); }
  .sev-high { color: var(--red); text-shadow: 0 0 6px rgba(255,0,60,.6); }

  footer { color: var(--green-dim); font-size: .78rem; text-align: center; margin-top: 2rem; }

  @media print {
    body { background: #000; }
    body::before { display: none; }
  }
</style>
</head>
<body>
<div class="wrap">
  <header class="hero">
    <div class="prompt">root@strix:~# ./strix --target {{ report.target }} --exfil<span class="blink">█</span></div>
    <h1>S T R I X</h1>
    <div class="sub">// intrusion recon framework · they watch in the dark</div>
    <div class="meta">
      <div><span class="k">TARGET ::</span> <span class="v">{{ report.target }}</span></div>
      <div><span class="k">VECTOR ::</span> <span class="v">{{ report.target_type.value }}</span></div>
      <div><span class="k">TIMESTAMP ::</span> <span class="v">{{ report.generated_at.strftime("%Y-%m-%d %H:%M:%S UTC") }}</span></div>
      <div><span class="k">INTEL ::</span> <span class="v">{{ report.total_findings }}</span></div>
      <div><span class="k">FAILED ::</span> <span class="v">{{ report.failed_modules | join(", ") or "none" }}</span></div>
    </div>
  </header>

  {% for module in report.modules %}
  <section class="card">
    <h2>{{ module.module }} <span class="dur">[ {{ "%.2f"|format(module.duration_s) }}s ]</span></h2>
    {% if module.error %}
      <p class="error">✗ {{ module.error }}</p>
    {% elif not module.findings %}
      <p class="empty">// no intel recovered</p>
    {% else %}
      <table>
        <thead>
          <tr><th>Title</th><th>Value</th><th>Source</th><th>Severity</th></tr>
        </thead>
        <tbody>
          {% for f in module.findings %}
          <tr>
            <td>{{ f.title }}</td>
            <td class="value">{% if f.url %}<a href="{{ f.url }}" target="_blank" rel="noopener">{{ f.value }}</a>{% else %}{{ f.value }}{% endif %}</td>
            <td>{{ f.source }}</td>
            <td><span class="badge sev-{{ f.severity.value }}">{{ f.severity.value }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </section>
  {% endfor %}

  <footer>// EOF · generated by STRIX · authorized use only</footer>
</div>
</body>
</html>
